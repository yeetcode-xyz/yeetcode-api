# Resend API Key for sending emails
RESEND_API_KEY=your_resend_api_key_here

# Server configuration
HOST=0.0.0.0
PORT=6969

# API Authentication
YETCODE_API_KEY=your_api_key_here

# Debug Mode (set to false in production)
DEBUG_MODE=true

# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here

# DynamoDB Table Names
USERS_TABLE=Yeetcode_users_table
DAILY_TABLE=Daily_problems
DUELS_TABLE=Duels_table
BOUNTIES_TABLE=Bounties_table

# Discord Webhooks (optional)
# For new user account creation notifications
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your_webhook_url_here
# For lambda/background task logs (daily problems, bounty updates, etc.)
DISCORD_LAMBDA_LOGS_WEBHOOK=https://discord.com/api/webhooks/your_lambda_logs_webhook_here
